<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Supermarket App</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">Supermarket App</a>

        <div class="navbar-nav">
            <a class="nav-link" href="/addProduct">Add New Product</a>
        </div>
    </div>
</nav>

<div class="container mt-4">

    <h2 class="text-center mb-4">
        Products from Supermarket App Database
    </h2>

    <table class="table table-bordered text-center align-middle">

        <thead class="table-dark">
            <tr>
                <th>Product Name</th>
                <th>Image</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Edit</th>
                <th>Delete</th>
            </tr>
        </thead>

        <tbody>

        <% products.forEach(product => { %>

        <tr>

            <td>
                <a href="/product/<%= product.productId %>">
                    <%= product.productName %>
                </a>
            </td>

            <td>
                <img src="/images/<%= product.image %>" width="100">
            </td>

            <td>
                <%= product.quantity %>
            </td>

            <td>
                $<%= product.price.toFixed(2) %>
            </td>

            <td>
                <a href="/updateProduct/<%= product.productId %>"
                class="btn btn-warning btn-sm">
                    Edit
                </a>
            </td>

            <td>
                <a href="/deleteProduct/<%= product.productId %>"
                class="btn btn-danger btn-sm">
                    Delete
                </a>
            </td>

        </tr>

        <% }) %>

        </tbody>

    </table>

</div>

</body>
</html>